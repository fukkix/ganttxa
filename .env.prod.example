# 生产环境配置示例
# 复制此文件为 .env.prod 并填写实际值

# 数据库密码（必须修改）
DB_PASSWORD=your_secure_db_password_here

# JWT 密钥（必须修改，建议使用随机字符串）
JWT_SECRET=your_secure_jwt_secret_here_at_least_32_characters

# CORS 来源（前端域名）
CORS_ORIGIN=https://ganttxa.yourdomain.com

# API URL（后端域名）
VITE_API_URL=https://api.ganttxa.yourdomain.com

# 或者使用 IP + 端口（如果不使用域名）
# CORS_ORIGIN=http://your-server-ip:8080
# VITE_API_URL=http://your-server-ip:3000
